# SmartOrder environment variables.
# Copy to ".env" and fill in real values. NEVER commit the real ".env".

# ---- Identity / OAuth2 (Keycloak) ----
# BFF confidential client secret (rotate in Keycloak; do not reuse the value from git history).
KEYCLOAK_BFF_SECRET=change-me
# Realm issuer used by all resource servers (must match the realm the BFF logs into).
SO_KEYCLOAK_ISSUER=http://localhost:8585/realms/smartorder-bff

# ---- Keycloak admin & its database (docker-compose) ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# ---- Platform infrastructure ----
SO_CONFIG_URI=http://localhost:8888
SO_EUREKA_URI=http://localhost:8761/eureka
# Host-run services use the Kafka EXTERNAL listener; containers override with kafka:9092.
SO_KAFKA_BROKERS=localhost:9094

# ---- Config Server (git backend) ----
SO_CONFIG_GIT_URI=https://github.com/halitkalayci/java-advanced-project3.git
SO_CONFIG_GIT_BRANCH=main

# ---- Config Server basic auth (clients authenticate with these) ----
SO_CONFIG_USER=configuser
SO_CONFIG_PASSWORD=change-me

# ---- Eureka basic auth (clients embed these in the registry URL) ----
SO_EUREKA_USER=eurekauser
SO_EUREKA_PASSWORD=change-me

# ---- Business databases (prod profile / PostgreSQL) ----
# In dev (default profile) services use file-based H2 and ignore these.
SO_DB_URL=jdbc:postgresql://localhost:5432/smartorder
SO_DB_USERNAME=smartorder
SO_DB_PASSWORD=change-me
